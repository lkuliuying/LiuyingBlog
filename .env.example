# 流萤博客环境变量配置示例
# 复制此文件为 .env 并填写实际值

# 核心安全配置
# 生产环境（DJANGO_DEBUG=False）必须设置真实密钥，否则启动会报错
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True  # 生产环境必须设为 False

# 允许的主机列表（逗号分隔）；不设置时回退到 settings.py 内置默认值
ALLOWED_HOSTS=127.0.0.1,localhost,yourdomain.com

# 邮箱配置
EMAIL_HOST_USER=your-email@qq.com
EMAIL_FROM_NAME=Your Blog Name
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=your-email@qq.com

# Redis 配置
REDIS_URL=redis://127.0.0.1:6379/1

# 数据库配置
# DB_ENGINE 可选：sqlite / mysql / postgresql，默认 sqlite
DB_ENGINE=sqlite
# 数据库名称：
# - sqlite 时为 SQLite 文件名（留空则用项目根目录 db.sqlite3）
# - mysql/postgresql 时为已创建的库名，如 liuyingblog
DB_NAME=db.sqlite3
# MySQL/PostgreSQL 连接参数（DB_ENGINE=sqlite 时忽略）
DB_USER=
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=
